          "script": {
            "exec": [
              "pm.test(\"Authentication correctly\", function () {\r",
              "\r",
              "    let body = pm.response.json();\r",
              "\r",
              "    pm.expect(body.access_token).to.not.be.empty;\r",
              "});\r",
              "\r",
              "if(pm.response.json().access_token){\r",
              "\r",
              "    pm.collectionVariables.set(\"TOKEN\", pm.response.json().access_token);\r",
